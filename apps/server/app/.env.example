# ──────────────────────────────────────────────────────────────
# GemyAI — Server Environment Variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────────

# ── AI Platform ──────────────────────────────────────────────
# Set to TRUE to use Vertex AI (recommended for GCP deployment)
# Set to FALSE to use Gemini API directly with an API key
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# For Gemini API (when GOOGLE_GENAI_USE_VERTEXAI=FALSE)
GOOGLE_API_KEY=your-gemini-api-key

# For Vertex AI (when GOOGLE_GENAI_USE_VERTEXAI=TRUE)
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# ── Model Selection (optional) ──────────────────────────────
# DEMO_AGENT_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
# GROUNDING_MODEL=gemini-3-flash-preview

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret

# ── JWT (session cookies) ────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret

# ── Firebase ─────────────────────────────────────────────────
# Path to service account JSON (local development)
FIREBASE_SERVICE_ACCOUNT_PATH=gemy-ai-firebase-adminsdk-xxxxx.json
# OR inline JSON from Secret Manager (production / Cloud Run)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── Runtime ──────────────────────────────────────────────────
# ENVIRONMENT=production  # Set in Cloud Run; enables secure cookies
